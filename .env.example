# Postgres
POSTGRES_USER=skillz
POSTGRES_PASSWORD=skillz
POSTGRES_DB=skillz
DATABASE_URL=postgresql://skillz:skillz@postgres:5432/skillz?schema=public

# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=4000
SANDBOX_URL=http://sandbox:8000
JWT_SECRET=change-me-in-prod

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Sandbox
SANDBOX_PORT=8000
SANDBOX_RUNNER_IMAGE=skillz-runner:latest
SANDBOX_DEFAULT_TIMEOUT_SEC=15
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
